<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="TOP_CENTER" spacing="10" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="org.example.snake.controller.GiocoController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>
    <Label fx:id="scoreLabel" style="-fx-font-size: 20px;" text="Punteggio: 0" />
    <HBox alignment="CENTER" spacing="10">
        <Button fx:id="btnAvvia" onAction="#onBtnAvviaClick" pickOnBounds="false" text="Avvia" />
        <Button fx:id="btnPausa" onAction="#onBtnPausaClick" text="Pausa" />
        <Button fx:id="btnRiavvia" onAction="#onBtnRiavviaClick" text="Riavvia" />
    </HBox>
    <Pane fx:id="gameArea" focusTraversable="true" onKeyPressed="#gestisciTastiera" prefHeight="400" prefWidth="600" style="-fx-border-color: black;" />
</VBox>
